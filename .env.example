# LandIntel configuration.
#
# Copy to .env and fill in the values. Keys map 1:1 to fields in
# src/landintel/config.py (the single source of truth). Required keys have no
# default and the app will refuse to start (ConfigError) until they are set.
# Never commit a real .env -- it is gitignored.

# --- App / tenancy -----------------------------------------------------------
ENVIRONMENT=local                     # local | production
CLIENT_ID=client_default              # the single hardcoded tenant for now
LOG_LEVEL=INFO

# --- MongoDB -----------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=landintel

# --- Redis (Celery broker + result backend) ----------------------------------
REDIS_URL=redis://localhost:6379/0

# --- AWS S3 (delivery) -------------------------------------------------------
# Optional for M1-only local work; required before M4 delivery runs.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
S3_BUCKET=your-bucket-name

# --- Anthropic (the agent brain) ---------------------------------------------
# REQUIRED. The agent layer (validator/anomaly/audit) cannot run without it.
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-opus-4-8

# --- OCR engine selection ----------------------------------------------------
# "paddle" locally (no GCP setup needed), "vision" in production once
# GOOGLE_CREDENTIALS_JSON is configured. Vision falls back to PaddleOCR when
# credentials are missing, so it's safe to set "vision" before they're ready.
OCR_ENGINE=paddle

# --- Google Cloud Vision (used when OCR_ENGINE=vision) -----------------------
# Paste the full service-account JSON content here for local testing.
# In production set this in the Render dashboard (sync: false) — never commit
# a real service-account key.
GOOGLE_CREDENTIALS_JSON=

# --- OCR (PaddleOCR PP-OCRv5) ------------------------------------------------
# Mobile det/rec locally (low RAM). In production switch OCR_DET_MODEL to the
# server det (e.g. PP-OCRv5_server_det) for higher accuracy.
OCR_DET_MODEL=PP-OCRv5_mobile_det
OCR_REC_MODEL=en_PP-OCRv5_mobile_rec
OCR_ZOOM=3.0
OCR_USE_MKLDNN=false                  # set true only if your CPU is stable with oneDNN

# --- ODA File Converter (DXF -> DWG, M2) -------------------------------------
# Absolute path to the ODA File Converter binary. Required before M2 runs.
ODA_CONVERTER_PATH=

# --- GIS / coordinate systems (pyproj, offline -- no API key needed) ---------
GIS_SOURCE_CRS=EPSG:4326        # WGS84, GPS lat/lng input
GIS_TARGET_CRS=EPSG:32644       # UTM Zone 44N, covers Tamil Nadu
GIS_SNAP_TOLERANCE_M=0.5        # metres, boundary snap threshold
